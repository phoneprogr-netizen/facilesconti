@model FacileSconti.Web.Areas.EndUser.ViewModels.EndUserProfileViewModel
@{ ViewData["Title"] = "Il mio profilo"; }

<h1 class="h3 mb-3">Il mio profilo</h1>
<div class="card border-0 shadow-sm">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Nome utente</dt>
            <dd class="col-sm-9">@Model.FullName</dd>
            <dt class="col-sm-3">Email</dt>
            <dd class="col-sm-9">@Model.Email</dd>
            <dt class="col-sm-3">Ultimo accesso area</dt>
            <dd class="col-sm-9">@Model.RegisteredAt.ToString("dd/MM/yyyy HH:mm")</dd>
        </dl>
    </div>
</div>
