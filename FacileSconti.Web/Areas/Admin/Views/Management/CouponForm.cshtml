@model FacileSconti.Web.Areas.Admin.ViewModels.AdminCouponFormViewModel
@{
    ViewData["Title"] = Model.Id.HasValue ? "Modifica Coupon" : "Nuovo Coupon";
}

<h1 class="h3 mb-3">@ViewData["Title"]</h1>

<form method="post" enctype="multipart/form-data" asp-action="@(Model.Id.HasValue ? "EditCoupon" : "NewCoupon")" class="row g-3">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    @if (Model.Id.HasValue)
    {
        <input type="hidden" asp-for="Id" />
    }
    <div class="col-md-6"><label asp-for="CustomerBusinessId" class="form-label">Cliente</label><select asp-for="CustomerBusinessId" asp-items="Model.AvailableCustomers" class="form-select"></select></div>
    <div class="col-md-6"><label asp-for="CouponCategoryId" class="form-label">Categoria</label><select asp-for="CouponCategoryId" asp-items="Model.AvailableCategories" class="form-select"></select></div>
    <div class="col-md-8"><label asp-for="Title" class="form-label"></label><input asp-for="Title" class="form-control" /></div>
    <div class="col-md-4"><label asp-for="Slug" class="form-label"></label><input asp-for="Slug" class="form-control" /></div>
    <div class="col-12"><label asp-for="ShortDescription" class="form-label"></label><input asp-for="ShortDescription" class="form-control" /></div>
    <div class="col-12"><label asp-for="FullDescription" class="form-label"></label><textarea asp-for="FullDescription" class="form-control" rows="4"></textarea></div>
    <div class="col-md-3"><label asp-for="OriginalPrice" class="form-label"></label><input asp-for="OriginalPrice" class="form-control" /></div>
    <div class="col-md-3"><label asp-for="DiscountedPrice" class="form-label"></label><input asp-for="DiscountedPrice" class="form-control" /></div>
    <div class="col-md-2"><label asp-for="CouponType" class="form-label"></label><select asp-for="CouponType" asp-items="Html.GetEnumSelectList<FacileSconti.Domain.Enums.CouponType>()" class="form-select"></select></div>
    <div class="col-md-2"><label asp-for="Status" class="form-label"></label><select asp-for="Status" asp-items="Html.GetEnumSelectList<FacileSconti.Domain.Enums.CouponStatus>()" class="form-select"></select></div>
    <div class="col-md-2"><label asp-for="MaxDownloads" class="form-label"></label><input asp-for="MaxDownloads" class="form-control" /></div>
    <div class="col-md-3"><label asp-for="ValidFrom" class="form-label"></label><input asp-for="ValidFrom" class="form-control" /></div>
    <div class="col-md-3"><label asp-for="ValidTo" class="form-label"></label><input asp-for="ValidTo" class="form-control" /></div>
    <div class="col-md-3 d-flex align-items-end"><div class="form-check"><input asp-for="IsFeatured" class="form-check-input" /><label asp-for="IsFeatured" class="form-check-label"></label></div></div>
    <div class="col-md-3 d-flex align-items-end"><div class="form-check"><input asp-for="IsBoostedInHome" class="form-check-input" /><label asp-for="IsBoostedInHome" class="form-check-label"></label></div></div>
    <div class="col-12">
        <label asp-for="ImageFiles" class="form-label"></label>
        <input asp-for="ImageFiles" type="file" class="form-control" accept="image/*" multiple />
        <div class="form-text">Minimo 1, massimo 5 immagini complessive per coupon.</div>
        <span asp-validation-for="ImageFiles" class="text-danger"></span>
    </div>
    @if (Model.ExistingImages.Count > 0)
    {
        <div class="col-12">
            <label class="form-label d-block">Immagini già caricate</label>
            <div class="row g-2">
                @foreach (var image in Model.ExistingImages)
                {
                    <div class="col-md-3 col-sm-6">
                        <div class="border rounded p-2 h-100">
                            <img src="@image.FilePath" alt="Immagine coupon" class="img-fluid rounded mb-2" style="height: 120px; width: 100%; object-fit: cover;" />
                            @if (image.IsPrimary)
                            {
                                <div class="small text-success mb-1">Immagine principale</div>
                            }
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" name="RemoveImageIds" value="@image.Id" id="removeImage_@image.Id" />
                                <label class="form-check-label small" for="removeImage_@image.Id">Rimuovi</label>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
    <div class="col-12 d-flex gap-2">
        <button class="btn btn-primary" type="submit">Salva</button>
        <a class="btn btn-outline-secondary" asp-action="Coupons">Annulla</a>
    </div>
</form>
