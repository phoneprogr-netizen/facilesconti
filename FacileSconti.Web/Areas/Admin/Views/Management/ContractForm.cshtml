@model FacileSconti.Web.Areas.Admin.ViewModels.AdminContractFormViewModel
@{
    ViewData["Title"] = Model.Id.HasValue ? "Modifica Contratto" : "Nuovo Contratto";
}

<h1 class="h3 mb-3">@ViewData["Title"]</h1>

<form method="post" asp-action="@(Model.Id.HasValue ? "EditContract" : "NewContract")" class="row g-3">
    @Html.AntiForgeryToken()
    @if (Model.Id.HasValue)
    {
        <input type="hidden" asp-for="Id" />
    }
    <div class="col-md-6">
        <label asp-for="CustomerBusinessId" class="form-label">Cliente</label>
        <select asp-for="CustomerBusinessId" asp-items="Model.AvailableCustomers" class="form-select"></select>
    </div>
    <div class="col-md-6">
        <label asp-for="SubscriptionPlanId" class="form-label">Piano</label>
        <select asp-for="SubscriptionPlanId" asp-items="Model.AvailablePlans" class="form-select"></select>
    </div>
    <div class="col-md-3"><label asp-for="StartDate" class="form-label"></label><input asp-for="StartDate" class="form-control" /></div>
    <div class="col-md-3"><label asp-for="EndDate" class="form-label"></label><input asp-for="EndDate" class="form-control" /></div>
    <div class="col-md-3"><label asp-for="Status" class="form-label"></label><select asp-for="Status" asp-items="Html.GetEnumSelectList<FacileSconti.Domain.Enums.ContractStatus>()" class="form-select"></select></div>
    <div class="col-md-3"><label asp-for="InitialPaymentMethod" class="form-label"></label><select asp-for="InitialPaymentMethod" asp-items="Html.GetEnumSelectList<FacileSconti.Domain.Enums.PaymentMethod>()" class="form-select"></select></div>
    <div class="col-md-3"><label asp-for="MaxActiveCoupons" class="form-label"></label><input asp-for="MaxActiveCoupons" class="form-control" /></div>
    <div class="col-md-3"><label asp-for="MaxDownloadsPerCoupon" class="form-label"></label><input asp-for="MaxDownloadsPerCoupon" class="form-control" /></div>
    <div class="col-md-3"><label asp-for="AgreedPrice" class="form-label"></label><input asp-for="AgreedPrice" class="form-control" /></div>
    <div class="col-md-3 d-flex align-items-end"><div class="form-check"><input asp-for="AutoRenewRequested" class="form-check-input" /><label asp-for="AutoRenewRequested" class="form-check-label"></label></div></div>
    <div class="col-md-3 d-flex align-items-end"><div class="form-check"><input asp-for="UnlimitedCoupons" class="form-check-input" /><label asp-for="UnlimitedCoupons" class="form-check-label"></label></div></div>
    <div class="col-md-3 d-flex align-items-end"><div class="form-check"><input asp-for="UnlimitedDownloads" class="form-check-input" /><label asp-for="UnlimitedDownloads" class="form-check-label"></label></div></div>
    <div class="col-12"><label asp-for="AdminNotes" class="form-label"></label><textarea asp-for="AdminNotes" class="form-control" rows="3"></textarea></div>
    <div class="col-12 d-flex gap-2">
        <button class="btn btn-primary" type="submit">Salva</button>
        <a class="btn btn-outline-secondary" asp-action="Contracts">Annulla</a>
    </div>
</form>
