@model IReadOnlyList<FacileSconti.Domain.Entities.Coupon>
@{
    ViewData["Title"] = "Gestione Coupon";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Gestione Coupon</h1>
    <a class="btn btn-primary" asp-action="NewCoupon">Nuovo coupon</a>
</div>

<table class="table table-striped table-hover align-middle">
    <thead>
    <tr>
        <th>Titolo</th>
        <th>Cliente</th>
        <th>Categoria</th>
        <th>Validità</th>
        <th>Stato</th>
        <th class="text-end">Azioni</th>
    </tr>
    </thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Title</td>
            <td>@item.CustomerBusiness.Name</td>
            <td>@item.CouponCategory.Name</td>
            <td>@item.ValidFrom - @item.ValidTo</td>
            <td>@item.Status</td>
            <td class="text-end">
                <a class="btn btn-outline-secondary btn-sm" asp-action="EditCoupon" asp-route-id="@item.Id">Modifica</a>
                <form class="d-inline" method="post" asp-action="DeleteCoupon" asp-route-id="@item.Id" onsubmit="return confirm('Confermi eliminazione coupon?');">
                    @Html.AntiForgeryToken()
                    <button class="btn btn-outline-danger btn-sm" type="submit">Elimina</button>
                </form>
            </td>
        </tr>
    }
    </tbody>
</table>
