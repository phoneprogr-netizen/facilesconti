@model FacileSconti.Web.Areas.Admin.ViewModels.AdminStatisticsViewModel
@{
    ViewData["Title"] = "Statistiche Admin";
}

<h1 class="h3 mb-3">Statistiche complete</h1>

<div class="row g-3 mb-4">
    <div class="col-md-3"><div class="border rounded p-3"><div class="text-secondary small">Clienti</div><strong>@Model.TotalCustomers</strong></div></div>
    <div class="col-md-3"><div class="border rounded p-3"><div class="text-secondary small">Contratti</div><strong>@Model.ActiveContracts / @Model.TotalContracts attivi/totali</strong></div></div>
    <div class="col-md-3"><div class="border rounded p-3"><div class="text-secondary small">Coupon</div><strong>@Model.ActiveCoupons / @Model.TotalCoupons attivi/totali</strong></div></div>
    <div class="col-md-3"><div class="border rounded p-3"><div class="text-secondary small">Pagamenti</div><strong>@Model.TotalPayments movimenti</strong></div></div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-6"><div class="alert alert-success mb-0">Incassato (Paid): <strong>@Model.PaidAmount.ToString("0.00") €</strong></div></div>
    <div class="col-md-6"><div class="alert alert-warning mb-0">In attesa (Pending): <strong>@Model.PendingAmount.ToString("0.00") €</strong></div></div>
</div>

<h2 class="h5">Dettaglio per cliente</h2>
<table class="table table-sm table-striped">
    <thead><tr><th>Cliente</th><th>Contratti</th><th>Coupon</th><th>Totale incassato</th></tr></thead>
    <tbody>
    @foreach (var item in Model.CustomerBreakdown)
    {
        <tr>
            <td>@item.CustomerName</td>
            <td>@item.ActiveContracts / @item.Contracts</td>
            <td>@item.ActiveCoupons / @item.Coupons</td>
            <td>@item.TotalPaid.ToString("0.00") €</td>
        </tr>
    }
    </tbody>
</table>
