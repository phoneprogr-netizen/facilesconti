@model FacileSconti.Web.Areas.Admin.ViewModels.AdminPlansViewModel
@{
    ViewData["Title"] = "Gestione piani";
}

<h1 class="h3 mb-3">Gestione piani</h1>

<div class="row g-4">
    <div class="col-lg-7">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <h2 class="h5 mb-3">Piani disponibili</h2>
                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Nome</th>
                                <th>Prezzo</th>
                                <th>Selezionabile fino al</th>
                                <th>Stato</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var plan in Model.Plans)
                        {
                            <tr>
                                <td>
                                    <div class="fw-semibold">@plan.Name</div>
                                    <small class="text-muted">@plan.Code</small>
                                </td>
                                <td>@plan.BasePrice.ToString("0.00")€</td>
                                <td>@(plan.SelectableUntil?.ToString("dd/MM/yyyy") ?? "Senza scadenza")</td>
                                <td>
                                    @if (plan.IsActive)
                                    {
                                        <span class="badge text-bg-success">Attivo</span>
                                    }
                                    else
                                    {
                                        <span class="badge text-bg-secondary">Disattivo</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <a class="btn btn-sm btn-outline-primary" asp-action="Plans" asp-route-id="@plan.Id">Modifica</a>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-5">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <h2 class="h5 mb-3">@(Model.Form.Id.HasValue ? "Modifica piano" : "Nuovo piano")</h2>
                <form method="post" asp-action="SavePlan" class="row g-3">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Form.Id" />

                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <div class="col-12">
                        <label asp-for="Form.Name" class="form-label"></label>
                        <input asp-for="Form.Name" class="form-control" />
                        <span asp-validation-for="Form.Name" class="text-danger"></span>
                    </div>
                    <div class="col-12">
                        <label asp-for="Form.Code" class="form-label"></label>
                        <input asp-for="Form.Code" class="form-control" />
                        <span asp-validation-for="Form.Code" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Form.BasePrice" class="form-label"></label>
                        <input asp-for="Form.BasePrice" class="form-control" />
                        <span asp-validation-for="Form.BasePrice" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Form.MaxActiveCoupons" class="form-label"></label>
                        <input asp-for="Form.MaxActiveCoupons" class="form-control" />
                        <span asp-validation-for="Form.MaxActiveCoupons" class="text-danger"></span>
                    </div>
                    <div class="col-12">
                        <label asp-for="Form.MaxDownloadsPerCoupon" class="form-label"></label>
                        <input asp-for="Form.MaxDownloadsPerCoupon" class="form-control" />
                        <span asp-validation-for="Form.MaxDownloadsPerCoupon" class="text-danger"></span>
                    </div>
                    <div class="col-12">
                        <label asp-for="Form.SelectableUntil" class="form-label"></label>
                        <input asp-for="Form.SelectableUntil" class="form-control" />
                        <span asp-validation-for="Form.SelectableUntil" class="text-danger"></span>
                    </div>
                    <div class="col-12">
                        <div class="form-check">
                            <input asp-for="Form.IsActive" class="form-check-input" />
                            <label asp-for="Form.IsActive" class="form-check-label">Piano attivo</label>
                        </div>
                        <div class="form-check">
                            <input asp-for="Form.UnlimitedCoupons" class="form-check-input" />
                            <label asp-for="Form.UnlimitedCoupons" class="form-check-label"></label>
                        </div>
                        <div class="form-check">
                            <input asp-for="Form.UnlimitedDownloads" class="form-check-input" />
                            <label asp-for="Form.UnlimitedDownloads" class="form-check-label"></label>
                        </div>
                        <div class="form-check">
                            <input asp-for="Form.AllowsBoost" class="form-check-input" />
                            <label asp-for="Form.AllowsBoost" class="form-check-label"></label>
                        </div>
                    </div>

                    <div class="col-12 d-flex gap-2">
                        <button type="submit" class="btn btn-primary">Salva piano</button>
                        <a asp-action="Plans" class="btn btn-outline-secondary">Nuovo</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
