@model IReadOnlyList<FacileSconti.Domain.Entities.PaymentRecord>
@{
    ViewData["Title"] = "Pagamenti";
}

<h1 class="h3 mb-3">Pagamenti contratti</h1>
<table class="table table-striped table-hover align-middle">
    <thead>
    <tr>
        <th>Data</th>
        <th>Cliente</th>
        <th>Contratto</th>
        <th>Metodo</th>
        <th>Stato</th>
        <th class="text-end">Importo</th>
    </tr>
    </thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.PaymentDate.ToString("dd/MM/yyyy HH:mm")</td>
            <td>@item.CustomerContract.CustomerBusiness.Name</td>
            <td>#@item.CustomerContractId</td>
            <td>@item.PaymentMethod</td>
            <td>@item.PaymentStatus</td>
            <td class="text-end">@item.Amount.ToString("0.00") €</td>
        </tr>
    }
    </tbody>
</table>
