@model FacileSconti.Web.Areas.Customer.ViewModels.CustomerRenewalViewModel
@{
    ViewData["Title"] = "Rinnovo";
    var payPalEnabled = ViewData["PayPalEnabled"] as bool? == true;
    var payPalClientId = ViewData["PayPalClientId"]?.ToString() ?? string.Empty;
    var payPalCurrencyCode = ViewData["PayPalCurrencyCode"]?.ToString() ?? "EUR";
    var payPalEnvironment = ViewData["PayPalEnvironment"]?.ToString() ?? "sandbox";
}
<h1 class="h3 mb-3">Rinnova il piano</h1>

@if (TempData["RenewalWarning"] is string renewalWarning)
{
    <div class="alert alert-warning">@renewalWarning</div>
}

@if (Model.AvailablePlans.Count == 0)
{
    <div class="alert alert-warning">Nessun piano disponibile al rinnovo in questo momento.</div>
}
else
{
    <form asp-action="Renewal" method="post" id="renewalForm">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

        <h2 class="h5 mb-2">1) Scegli il piano</h2>
        <div class="row g-3 mb-4">
            @foreach (var plan in Model.AvailablePlans)
            {
                <div class="col-lg-4 col-md-6">
                    <label class="card border-0 shadow-sm h-100 w-100">
                        <div class="card-body d-flex flex-column">
                            <div class="form-check mb-2">
                                <input class="form-check-input"
                                       type="radio"
                                       asp-for="Input.SubscriptionPlanId"
                                       value="@plan.Id"
                                       checked="@(Model.Input.SubscriptionPlanId == plan.Id)" />
                                <span class="form-check-label fw-semibold">@plan.Name</span>
                            </div>
                            <p class="text-muted small mb-2">@plan.Code</p>
                            <p class="fs-5 fw-semibold">@plan.BasePrice.ToString("0.00")€ / mese</p>
                            <ul class="small ps-3">
                                <li>@(plan.UnlimitedCoupons ? "Coupon illimitati" : $"{plan.MaxActiveCoupons} coupon attivi")</li>
                                <li>@(plan.UnlimitedDownloads ? "Download illimitati" : plan.MaxDownloadsPerCoupon.HasValue ? $"{plan.MaxDownloadsPerCoupon} download max" : "Download da contratto")</li>
                                <li>@(plan.AllowsBoost ? "Boost incluso" : "Boost non incluso")</li>
                            </ul>
                            @if (plan.SelectableUntil.HasValue)
                            {
                                <p class="small text-muted mt-auto mb-0">Selezionabile fino al @plan.SelectableUntil.Value.ToString("dd/MM/yyyy")</p>
                            }
                        </div>
                    </label>
                </div>
            }
        </div>
        <span asp-validation-for="Input.SubscriptionPlanId" class="text-danger d-block mb-3"></span>

        <h2 class="h5 mb-2">2) Metodo di pagamento</h2>
        <div class="list-group mb-3">
            @foreach (var method in Model.PaymentMethods)
            {
                var isSelected = Model.Input.PaymentMethodCode == method.Code;
                <label class="list-group-item list-group-item-action d-flex gap-3 align-items-start">
                    <input class="form-check-input mt-1"
                           type="radio"
                           asp-for="Input.PaymentMethodCode"
                           value="@method.Code"
                           checked="@isSelected" />
                    <div>
                        <strong>@method.Name</strong>
                        @if (method.IsDefault)
                        {
                            <span class="badge bg-success ms-2">Attivo</span>
                        }
                        else
                        {
                            <span class="badge text-bg-light ms-2">Prossimamente</span>
                        }
                        <p class="small text-muted mb-0">@method.Description</p>
                    </div>
                </label>
            }
        </div>
        <span asp-validation-for="Input.PaymentMethodCode" class="text-danger d-block mb-3"></span>

        <button type="submit" class="btn btn-primary" id="standardCheckoutButton">Procedi al pagamento</button>
        <div class="mt-3 @(payPalEnabled ? string.Empty : "d-none")" id="paypalCheckoutContainer">
            <div id="paypal-button-container"></div>
            <p class="small text-muted mb-0">Ambiente PayPal attivo: <strong>@payPalEnvironment</strong>.</p>
        </div>
    </form>
}

@if (payPalEnabled && !string.IsNullOrWhiteSpace(payPalClientId))
{
    <script src="https://www.paypal.com/sdk/js?client-id=@payPalClientId&currency=@payPalCurrencyCode&intent=capture"></script>
    <script>
        (() => {
            const paymentInputs = document.querySelectorAll('input[name="Input.PaymentMethodCode"]');
            const planInput = () => document.querySelector('input[name="Input.SubscriptionPlanId"]:checked');
            const paypalContainer = document.getElementById('paypalCheckoutContainer');
            const standardButton = document.getElementById('standardCheckoutButton');
            const antiForgeryToken = document.querySelector('input[name="__RequestVerificationToken"]')?.value;

            const toggleCheckoutMode = () => {
                const selectedMethod = document.querySelector('input[name="Input.PaymentMethodCode"]:checked')?.value;
                const isPayPal = selectedMethod === 'paypal';
                paypalContainer?.classList.toggle('d-none', !isPayPal);
                standardButton?.classList.toggle('d-none', isPayPal);
            };

            paymentInputs.forEach(input => input.addEventListener('change', toggleCheckoutMode));
            toggleCheckoutMode();

            paypal.Buttons({
                createOrder: async () => {
                    const selectedPlan = planInput()?.value;
                    if (!selectedPlan) throw new Error('Seleziona un piano prima di procedere.');

                    const response = await fetch('@Url.Action("CreatePayPalOrder", "CouponManagement", new { area = "Customer" })', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'RequestVerificationToken': antiForgeryToken
                        },
                        body: JSON.stringify({
                            subscriptionPlanId: Number(selectedPlan),
                            paymentMethodCode: 'paypal'
                        })
                    });

                    const payload = await response.json();
                    if (!response.ok || !payload.id) {
                        throw new Error(payload.message || 'Errore durante la creazione ordine PayPal.');
                    }
                    return payload.id;
                },
                onApprove: async (data) => {
                    const response = await fetch('@Url.Action("CapturePayPalOrder", "CouponManagement", new { area = "Customer" })', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'RequestVerificationToken': antiForgeryToken
                        },
                        body: JSON.stringify({ orderId: data.orderID })
                    });

                    const payload = await response.json();
                    if (!response.ok || !payload.success) {
                        alert(payload.message || 'Pagamento acquisito ma conferma locale fallita.');
                        return;
                    }

                    if (payload.redirectUrl) {
                        window.location.href = payload.redirectUrl;
                    }
                },
                onError: (err) => {
                    console.error('PayPal error', err);
                    alert('Errore PayPal: controlla configurazione ambiente e credenziali.');
                }
            }).render('#paypal-button-container');
        })();
    </script>
}
