@model FacileSconti.Application.DTOs.CustomerDashboardDto
@{ ViewData["Title"] = "Dashboard cliente"; }

<h1 class="h3 mb-3">Dashboard Cliente</h1>

@if (Model is null)
{
    <div class="alert alert-warning rounded-4">Nessun contratto attivo trovato per questa utenza.</div>
}
else
{
    <div class="row g-3">
        <div class="col-md-6 col-xl-3"><div class="card border-0 shadow-sm h-100"><div class="card-body"><div class="text-muted small">Azienda</div><div class="fw-semibold">@Model.BusinessName</div></div></div></div>
        <div class="col-md-6 col-xl-3"><div class="card border-0 shadow-sm h-100"><div class="card-body"><div class="text-muted small">Piano</div><div class="fw-semibold">@Model.PlanName</div></div></div></div>
        <div class="col-md-6 col-xl-3"><div class="card border-0 shadow-sm h-100"><div class="card-body"><div class="text-muted small">Scadenza contratto</div><div class="fw-semibold">@Model.DaysToExpiration giorni</div></div></div></div>
        <div class="col-md-6 col-xl-3"><div class="card border-0 shadow-sm h-100"><div class="card-body"><div class="text-muted small">Coupon attivi</div><div class="fw-semibold">@Model.ActiveCoupons</div></div></div></div>
    </div>

    <div class="card border-0 shadow-sm mt-3">
        <div class="card-body d-flex justify-content-between align-items-center flex-wrap gap-2">
            <div>
                <div class="text-muted small">Download ultimi 30 giorni</div>
                <div class="h4 mb-0">@Model.MonthlyDownloads</div>
            </div>
            <div class="d-flex gap-2">
                <a asp-controller="CouponManagement" asp-action="Coupons" class="btn btn-outline-primary">Gestisci coupon</a>
                <a asp-controller="CouponManagement" asp-action="Statistics" class="btn btn-primary">Apri statistiche</a>
            </div>
        </div>
    </div>
}
