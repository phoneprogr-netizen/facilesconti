@model FacileSconti.Application.DTOs.CouponCardDto
<div class="card h-100 shadow-sm coupon-card">
  <div class="coupon-card-image-wrap">
    @if (!string.IsNullOrWhiteSpace(Model.ImagePath))
    {
      <img src="@Model.ImagePath" class="coupon-card-image" alt="Immagine coupon @Model.Title" />
    }
    else
    {
      <div class="coupon-card-image coupon-card-image-placeholder d-flex align-items-center justify-content-center text-muted">
        Nessuna immagine
      </div>
    }
  </div>

  <div class="card-body">
    <div class="d-flex justify-content-between align-items-center mb-2">
      <span class="badge bg-secondary">@Model.CategoryName</span>
      @if (Model.IsBoostedInHome)
      {
        <span class="badge bg-warning text-dark">Boost</span>
      }
    </div>

    <h5 class="mt-2">@Model.Title</h5>
    <p class="small text-muted mb-1">@Model.BusinessName</p>
    @if (!string.IsNullOrWhiteSpace(Model.BusinessCity))
    {
      <p class="small text-muted mb-2"><i class="bi bi-geo-alt"></i> @Model.BusinessCity</p>
    }

    <p class="small mb-3">Scade il @Model.ValidTo.ToString("dd/MM/yyyy")</p>
    <a class="btn btn-outline-primary btn-sm" asp-controller="Coupons" asp-action="Detail" asp-route-slug="@Model.Slug">Dettaglio</a>
  </div>
</div>
