<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - Facile Sconti</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
</head>
<body>
<nav class="navbar navbar-expand-lg navbar-dark bg-dark sticky-top">
    <div class="container">
        <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">Facile Sconti</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="mainNav">
            <div class="navbar-nav me-auto">
                <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                <a class="nav-link" asp-area="" asp-controller="Coupons" asp-action="Index">Coupon</a>
                @if (!User.IsInRole("Customer"))
                {
                    <a class="nav-link" asp-area="" asp-controller="StaticPage" asp-action="DiventaCliente">Diventa cliente</a>
                }
                <a class="nav-link" asp-area="" asp-controller="StaticPage" asp-action="ChiSiamo">Chi siamo</a>
                <a class="nav-link" asp-area="" asp-controller="StaticPage" asp-action="Contatti">Contatti</a>
            </div>
            <div class="navbar-nav align-items-lg-center gap-lg-2">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    @if (User.IsInRole("Admin"))
                    {
                        <a class="nav-link" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">Admin</a>
                    }
                    else if (User.IsInRole("Customer"))
                    {
                        <a class="nav-link" asp-area="Customer" asp-controller="Dashboard" asp-action="Index">Area Cliente</a>
                    }
                    else
                    {
                        <a class="nav-link" asp-area="EndUser" asp-controller="Dashboard" asp-action="Index">Area Utente</a>
                    }

                    <form method="post" asp-area="" asp-controller="Account" asp-action="Logout">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-outline-light btn-sm">Esci</button>
                    </form>
                }
                else
                {
                    <a class="btn btn-primary btn-sm" asp-area="" asp-controller="Account" asp-action="Login">Login</a>
                }
            </div>
        </div>
    </div>
</nav>
@if (User.Identity?.IsAuthenticated == true)
{
    var currentArea = ViewContext.RouteData.Values["area"]?.ToString() ?? string.Empty;
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty;
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? string.Empty;

    string ActiveClass(string area, string controller, string action)
        => string.Equals(currentArea, area, StringComparison.OrdinalIgnoreCase) &&
           string.Equals(currentController, controller, StringComparison.OrdinalIgnoreCase) &&
           string.Equals(currentAction, action, StringComparison.OrdinalIgnoreCase)
            ? "active"
            : string.Empty;

    <div class="bg-light border-bottom">
        <div class="container py-2">
            <div class="nav nav-pills flex-wrap gap-2">
                @if (User.IsInRole("Admin"))
                {
                    <a class="nav-link @ActiveClass("Admin", "Dashboard", "Index")" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">Dashboard admin</a>
                    <a class="nav-link @ActiveClass("Admin", "Management", "Customers")" asp-area="Admin" asp-controller="Management" asp-action="Customers">Clienti</a>
                    <a class="nav-link @ActiveClass("Admin", "Management", "Contracts")" asp-area="Admin" asp-controller="Management" asp-action="Contracts">Contratti</a>
                    <a class="nav-link @ActiveClass("Admin", "Management", "Coupons")" asp-area="Admin" asp-controller="Management" asp-action="Coupons">Coupon</a>
                    <a class="nav-link @ActiveClass("Admin", "Management", "Payments")" asp-area="Admin" asp-controller="Management" asp-action="Payments">Pagamenti</a>
                    <a class="nav-link @ActiveClass("Admin", "Management", "Statistics")" asp-area="Admin" asp-controller="Management" asp-action="Statistics">Statistiche</a>
                }
                else if (User.IsInRole("Customer"))
                {
                    <a class="nav-link @ActiveClass("Customer", "Dashboard", "Index")" asp-area="Customer" asp-controller="Dashboard" asp-action="Index">Dashboard cliente</a>
                    <a class="nav-link @ActiveClass("Customer", "CouponManagement", "CreateCoupon")" asp-area="Customer" asp-controller="CouponManagement" asp-action="CreateCoupon">Nuovo coupon</a>
                    <a class="nav-link @ActiveClass("Customer", "CouponManagement", "Coupons")" asp-area="Customer" asp-controller="CouponManagement" asp-action="Coupons">I miei coupon</a>
                    <a class="nav-link @ActiveClass("Customer", "CouponManagement", "Contract")" asp-area="Customer" asp-controller="CouponManagement" asp-action="Contract">Contratto</a>
                    <a class="nav-link @ActiveClass("Customer", "CouponManagement", "Renewal")" asp-area="Customer" asp-controller="CouponManagement" asp-action="Renewal">Rinnovo</a>
                    <a class="nav-link @ActiveClass("Customer", "CouponManagement", "Profile")" asp-area="Customer" asp-controller="CouponManagement" asp-action="Profile">Profilo</a>
                    <a class="nav-link @ActiveClass("Customer", "CouponManagement", "Statistics")" asp-area="Customer" asp-controller="CouponManagement" asp-action="Statistics">Statistiche</a>
                    <a class="nav-link @ActiveClass("Customer", "CouponManagement", "Boost")" asp-area="Customer" asp-controller="CouponManagement" asp-action="Boost">Boost</a>
                }
                else if (User.IsInRole("EndUser"))
                {
                    <a class="nav-link @ActiveClass("EndUser", "Dashboard", "Index")" asp-area="EndUser" asp-controller="Dashboard" asp-action="Index">Dashboard utente</a>
                    <a class="nav-link @ActiveClass("EndUser", "Profile", "Profile")" asp-area="EndUser" asp-controller="Profile" asp-action="Profile">Profilo</a>
                    <a class="nav-link @ActiveClass("EndUser", "Profile", "MyCoupons")" asp-area="EndUser" asp-controller="Profile" asp-action="MyCoupons">I miei coupon</a>
                    <a class="nav-link @ActiveClass("EndUser", "Profile", "Newsletter")" asp-area="EndUser" asp-controller="Profile" asp-action="Newsletter">Newsletter</a>
                }
            </div>
        </div>
    </div>
}
<main class="container py-4">@RenderBody()</main>
<footer class="bg-light border-top py-4 mt-5">
    <div class="container small d-flex flex-column flex-md-row justify-content-between gap-2">
        <span>© @DateTime.UtcNow.Year Facile Sconti</span>
        <div class="d-flex gap-3">
            <a class="text-muted" asp-area="" asp-controller="StaticPage" asp-action="Privacy">Privacy</a>
            <a class="text-muted" asp-area="" asp-controller="StaticPage" asp-action="Cookie">Cookie</a>
        </div>
    </div>
</footer>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
