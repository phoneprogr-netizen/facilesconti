<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - Facile Sconti</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
</head>
<body>
<nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container">
        <a class="navbar-brand" asp-controller="Home" asp-action="Index">Facile Sconti</a>
        <div class="navbar-nav">
            <a class="nav-link" asp-controller="Coupons" asp-action="Index">Coupon</a>
            <a class="nav-link" asp-controller="StaticPage" asp-action="DiventaCliente">Diventa cliente</a>
            <a class="nav-link" asp-controller="Account" asp-action="Login">Login</a>
        </div>
    </div>
</nav>
<main class="container py-4">@RenderBody()</main>
<footer class="bg-light border-top py-4"><div class="container small">© Facile Sconti</div></footer>
</body>
</html>
