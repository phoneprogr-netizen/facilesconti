<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - Facile Sconti</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
</head>
<body>
<nav class="navbar navbar-expand-lg navbar-dark bg-dark sticky-top">
    <div class="container">
        <a class="navbar-brand" asp-controller="Home" asp-action="Index">Facile Sconti</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="mainNav">
            <div class="navbar-nav me-auto">
                <a class="nav-link" asp-controller="Home" asp-action="Index">Home</a>
                <a class="nav-link" asp-controller="Coupons" asp-action="Index">Coupon</a>
                <a class="nav-link" asp-controller="StaticPage" asp-action="DiventaCliente">Diventa cliente</a>
                <a class="nav-link" asp-controller="StaticPage" asp-action="ChiSiamo">Chi siamo</a>
                <a class="nav-link" asp-controller="StaticPage" asp-action="Contatti">Contatti</a>
            </div>
            <div class="navbar-nav align-items-lg-center gap-lg-2">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    @if (User.IsInRole("Admin"))
                    {
                        <a class="nav-link" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">Admin</a>
                    }
                    else if (User.IsInRole("Customer"))
                    {
                        <a class="nav-link" asp-area="Customer" asp-controller="Dashboard" asp-action="Index">Area Cliente</a>
                    }
                    else
                    {
                        <a class="nav-link" asp-area="EndUser" asp-controller="Dashboard" asp-action="Index">Area Utente</a>
                    }

                    <form method="post" asp-controller="Account" asp-action="Logout">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-outline-light btn-sm">Esci</button>
                    </form>
                }
                else
                {
                    <a class="btn btn-primary btn-sm" asp-controller="Account" asp-action="Login">Login</a>
                }
            </div>
        </div>
    </div>
</nav>
<main class="container py-4">@RenderBody()</main>
<footer class="bg-light border-top py-4 mt-5">
    <div class="container small d-flex flex-column flex-md-row justify-content-between gap-2">
        <span>© @DateTime.UtcNow.Year Facile Sconti</span>
        <div class="d-flex gap-3">
            <a class="text-muted" asp-controller="StaticPage" asp-action="Privacy">Privacy</a>
            <a class="text-muted" asp-controller="StaticPage" asp-action="Cookie">Cookie</a>
        </div>
    </div>
</footer>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
