@{
    ViewData["Title"] = "Contatti";
}

<section class="container py-4 py-lg-5 static-page">
    <div class="static-page-hero contact-hero mb-4 mb-lg-5">
        <span class="badge rounded-pill text-bg-light text-brand-blue mb-3">Facile Sconti</span>
        <h1 class="display-6 fw-bold mb-3">Contatti</h1>
        <p class="lead mb-0">
            Per informazioni, supporto tecnico, segnalazioni o richieste commerciali puoi scriverci in qualsiasi momento.
            Ti risponderemo nel minor tempo possibile.
        </p>
    </div>

    <div class="row g-4">
        <div class="col-12 col-lg-7">
            <div class="info-panel h-100">
                <h2 class="h4 mb-3">Come contattarci</h2>
                <p class="text-muted mb-4">
                    Scegli il canale più adatto alla tua richiesta. Il team Facile Sconti è a disposizione per supportarti.
                </p>

                <div class="contact-list">
                    <a class="contact-item" href="mailto:customer@facilesconti.com">
                        <div>
                            <p class="contact-label mb-1">Assistenza clienti</p>
                            <p class="mb-0">customer@facilesconti.com</p>
                        </div>
                        <span aria-hidden="true">→</span>
                    </a>

                    <a class="contact-item" href="mailto:info@facilesconti.com">
                        <div>
                            <p class="contact-label mb-1">Informazioni generali</p>
                            <p class="mb-0">info@facilesconti.com</p>
                        </div>
                        <span aria-hidden="true">→</span>
                    </a>

                    <a class="contact-item" href="mailto:visionhubsrl@messaggipec.it">
                        <div>
                            <p class="contact-label mb-1">PEC</p>
                            <p class="mb-0">visionhubsrl@messaggipec.it</p>
                        </div>
                        <span aria-hidden="true">→</span>
                    </a>
                </div>
            </div>
        </div>

        <div class="col-12 col-lg-5">
            <aside class="company-card h-100">
                <h2 class="h5 mb-3">Dati societari</h2>
                <p class="mb-1"><strong>VISIONHUB S.R.L.</strong></p>
                <p class="mb-1">Corso Vercelli 9, 20144 Milano (MI), Italia</p>
                <p class="mb-1">P.IVA: 13468660967</p>
                <p class="mb-1">Codice univoco: M5UXCR1</p>
                <p class="mb-0">Brand: Facile Sconti</p>
            </aside>
        </div>
    </div>
</section>
