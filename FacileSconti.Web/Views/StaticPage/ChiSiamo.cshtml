@{
    ViewData["Title"] = "Chi siamo";
}

<section class="container py-4 py-lg-5 static-page">
    <div class="static-page-hero about-hero mb-4 mb-lg-5">
        <span class="badge rounded-pill text-bg-light text-brand-green mb-3">La nostra identità</span>
        <h1 class="display-6 fw-bold mb-3">Chi siamo</h1>
        <p class="lead mb-0">
            <strong>Facile Sconti</strong> è il brand di <strong>VISIONHUB S.R.L.</strong> che mette in contatto attività locali
            e persone in cerca di offerte reali, semplici da trovare e immediate da usare.
        </p>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-12 col-lg-6">
            <div class="info-panel h-100">
                <h2 class="h4 mb-3">La nostra missione</h2>
                <p class="mb-0 text-muted">
                    Aiutiamo negozi, professionisti e imprese a valorizzare i propri servizi,
                    offrendo agli utenti un modo intuitivo per scoprire promozioni affidabili nel proprio territorio.
                </p>
            </div>
        </div>
        <div class="col-12 col-lg-6">
            <div class="info-panel h-100">
                <h2 class="h4 mb-3">Cosa facciamo</h2>
                <ul class="feature-list mb-0">
                    <li>Rendiamo più visibili le promozioni delle attività locali.</li>
                    <li>Offriamo una consultazione intuitiva da desktop e mobile.</li>
                    <li>Supportiamo i partner commerciali con strumenti semplici di pubblicazione.</li>
                    <li>Favoriamo una relazione trasparente tra aziende e clienti finali.</li>
                </ul>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-12 col-lg-7">
            <div class="values-panel h-100">
                <h2 class="h4 mb-3">I nostri valori</h2>
                <div class="row g-3">
                    <div class="col-12 col-sm-6">
                        <div class="value-chip"><strong>Trasparenza</strong><span>Informazioni chiare su offerte e condizioni.</span></div>
                    </div>
                    <div class="col-12 col-sm-6">
                        <div class="value-chip"><strong>Semplicità</strong><span>Esperienza d'uso immediata e accessibile.</span></div>
                    </div>
                    <div class="col-12 col-sm-6">
                        <div class="value-chip"><strong>Affidabilità</strong><span>Massima attenzione alla qualità dei contenuti.</span></div>
                    </div>
                    <div class="col-12 col-sm-6">
                        <div class="value-chip"><strong>Crescita locale</strong><span>Valorizziamo il commercio e i servizi di prossimità.</span></div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-lg-5">
            <aside class="company-card h-100">
                <h2 class="h5 mb-3">Società</h2>
                <p class="mb-1"><strong>VISIONHUB S.R.L.</strong></p>
                <p class="mb-1">Corso Vercelli 9, 20144 Milano (MI), Italia</p>
                <p class="mb-1">P.IVA: 13468660967</p>
                <p class="mb-1">PEC: visionhubsrl@messaggipec.it</p>
                <p class="mb-0">Codice univoco: M5UXCR1</p>
            </aside>
        </div>
    </div>
</section>
