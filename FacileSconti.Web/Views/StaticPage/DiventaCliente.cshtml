@model IReadOnlyList<FacileSconti.Web.Areas.Customer.ViewModels.PlanSelectionItemViewModel>
@{
    ViewData["Title"] = "Diventa cliente";
}

<section class="mb-5">
    <div class="static-page-hero customer-hero">
        <div class="row g-4 align-items-center">
            <div class="col-lg-8">
                <span class="badge text-bg-light text-brand-blue fw-semibold mb-3">Per attività e negozi locali</span>
                <h1 class="display-5 fw-bold mb-3">Diventa cliente Facile Sconti</h1>
                <p class="lead mb-0">
                    Porta più persone nel tuo punto vendita con coupon digitali, statistiche in tempo reale
                    e una gestione semplice da un'unica dashboard.
                </p>
            </div>
            <div class="col-lg-4">
                <div class="hero-highlight">
                    <p class="small text-uppercase fw-semibold mb-2">Attivazione rapida</p>
                    <ul class="feature-list text-white mb-0">
                        <li>Pubblica i tuoi coupon in pochi minuti</li>
                        <li>Monitora download e redemption in tempo reale</li>
                        <li>Aggiorna piano o servizi quando vuoi</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="mb-5">
    <h2 class="h4 mb-3">Piani attivabili ora</h2>
    @if (Model.Count == 0)
    {
        <div class="alert alert-warning mb-0">
            Al momento non ci sono piani acquistabili. Contatta l'amministrazione per maggiori dettagli.
        </div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var plan in Model)
            {
                <div class="col-md-4">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body d-flex flex-column">
                            <h3 class="h5">@plan.Name</h3>
                            <p class="text-muted small mb-2">Codice piano: @plan.Code</p>
                            <p class="fs-5 fw-semibold mb-3">@plan.BasePrice.ToString("0.00")€ / mese</p>
                            <ul class="mb-3 ps-3 small flex-grow-1">
                                <li>
                                    @(plan.UnlimitedCoupons
                                        ? "Coupon attivi illimitati"
                                        : $"Fino a {plan.MaxActiveCoupons} coupon attivi")
                                </li>
                                <li>
                                    @(plan.UnlimitedDownloads
                                        ? "Download illimitati"
                                        : plan.MaxDownloadsPerCoupon.HasValue
                                            ? $"Max {plan.MaxDownloadsPerCoupon} download per coupon"
                                            : "Download secondo regole contratto")
                                </li>
                                <li>
                                    @(plan.AllowsBoost
                                        ? "Supporta boost in homepage"
                                        : "Boost homepage non incluso")
                                </li>
                            </ul>
                            @if (plan.SelectableUntil.HasValue)
                            {
                                <p class="small text-muted mb-0">Selezionabile fino al @plan.SelectableUntil.Value.ToString("dd/MM/yyyy")</p>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</section>

<section class="mb-5">
    <h2 class="h4 mb-3">Pagamenti e rinnovi</h2>
    <div class="alert alert-light border mb-0">
        <ul class="mb-0 ps-3">
            <li>Pagamento mensile o annuale con carta o bonifico.</li>
            <li>Fattura automatica disponibile nell'area cliente.</li>
            <li>Rinnovo automatico disattivabile in qualsiasi momento senza penali.</li>
            <li>Upgrade o downgrade del piano dalla dashboard con conguaglio trasparente.</li>
        </ul>
    </div>
</section>

<section class="mb-5">
    <div class="alert alert-primary d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3 mb-0">
        <div>
            <h2 class="h5 mb-1">Pronto a iniziare?</h2>
            <p class="mb-0">Registra subito la tua attività dalla pagina dedicata ai nuovi clienti business.</p>
        </div>
        <a class="btn btn-primary" asp-controller="Account" asp-action="RegisterBusiness">Vai alla registrazione cliente</a>
    </div>
</section>
