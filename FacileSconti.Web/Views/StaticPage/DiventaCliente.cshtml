@{
    ViewData["Title"] = "Diventa cliente";
}

<section class="mb-5">
    <h1 class="display-6 fw-bold">Diventa cliente Facile Sconti</h1>
    <p class="lead text-muted mb-0">
        Porta più persone nel tuo punto vendita con coupon digitali, statistiche in tempo reale e una gestione semplice da un'unica dashboard.
    </p>
</section>

<section class="mb-5">
    <h2 class="h4 mb-3">Abbonamenti disponibili</h2>
    <div class="row g-3">
        <div class="col-md-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <h3 class="h5">Start</h3>
                    <p class="text-muted small mb-3">Perfetto per iniziare con pochi coupon al mese.</p>
                    <p class="fs-5 fw-semibold mb-3">29€ / mese</p>
                    <ul class="mb-0 ps-3 small">
                        <li>Fino a 10 coupon attivi</li>
                        <li>Statistiche base visualizzazioni/download</li>
                        <li>Supporto email</li>
                    </ul>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 shadow-sm border-primary">
                <div class="card-body">
                    <h3 class="h5">Business</h3>
                    <p class="text-muted small mb-3">Per attività che vogliono crescere in modo costante.</p>
                    <p class="fs-5 fw-semibold mb-3">59€ / mese</p>
                    <ul class="mb-0 ps-3 small">
                        <li>Fino a 40 coupon attivi</li>
                        <li>Statistiche avanzate e conversioni</li>
                        <li>2 campagne boost incluse</li>
                    </ul>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <h3 class="h5">Premium</h3>
                    <p class="text-muted small mb-3">Massima visibilità per negozi multi-sede o franchising.</p>
                    <p class="fs-5 fw-semibold mb-3">99€ / mese</p>
                    <ul class="mb-0 ps-3 small">
                        <li>Coupon illimitati</li>
                        <li>Priorità nelle sezioni in evidenza</li>
                        <li>Supporto prioritario</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="mb-5">
    <h2 class="h4 mb-3">Pagamenti e rinnovi</h2>
    <div class="alert alert-light border mb-0">
        <ul class="mb-0 ps-3">
            <li>Pagamento mensile o annuale con carta o bonifico.</li>
            <li>Fattura automatica disponibile nell'area cliente.</li>
            <li>Rinnovo automatico disattivabile in qualsiasi momento senza penali.</li>
            <li>Upgrade o downgrade del piano dalla dashboard con conguaglio trasparente.</li>
        </ul>
    </div>
</section>

<section>
    <h2 class="h4 mb-3">Come funziona per i clienti registrati</h2>
    <ol class="ps-3 mb-0">
        <li class="mb-2">Ti registri con il tuo account business e completi i dati attività.</li>
        <li class="mb-2">Scegli l'abbonamento più adatto e attivi il metodo di pagamento.</li>
        <li class="mb-2">Pubblichi i coupon, monitori risultati e rinnovi tutto dall'area cliente.</li>
    </ol>
</section>
