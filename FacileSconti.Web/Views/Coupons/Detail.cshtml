@model FacileSconti.Web.ViewModels.CouponDetailViewModel
@{
    ViewData["Title"] = Model.Coupon.Title;
}

<div class="row g-4">
    <div class="col-lg-7">
        <div class="card shadow-sm border-0 coupon-detail-card">
            @if (Model.Coupon.ImagePaths.Count > 1)
            {
                var carouselId = $"couponImagesCarousel{Model.Coupon.Id}";
                <div id="@carouselId" class="carousel slide" data-bs-ride="carousel">
                    <div class="carousel-indicators">
                        @for (var i = 0; i < Model.Coupon.ImagePaths.Count; i++)
                        {
                            <button type="button"
                                    data-bs-target="#@carouselId"
                                    data-bs-slide-to="@i"
                                    class="@(i == 0 ? "active" : string.Empty)"
                                    aria-current="@(i == 0 ? "true" : "false")"
                                    aria-label="Slide @(i + 1)"></button>
                        }
                    </div>
                    <div class="carousel-inner">
                        @for (var i = 0; i < Model.Coupon.ImagePaths.Count; i++)
                        {
                            <div class="carousel-item @(i == 0 ? "active" : string.Empty)">
                                <img src="@Model.Coupon.ImagePaths[i]" class="coupon-detail-image d-block w-100" alt="Immagine @(i + 1) coupon @Model.Coupon.Title" />
                            </div>
                        }
                    </div>
                    <button class="carousel-control-prev" type="button" data-bs-target="#@carouselId" data-bs-slide="prev">
                        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                        <span class="visually-hidden">Precedente</span>
                    </button>
                    <button class="carousel-control-next" type="button" data-bs-target="#@carouselId" data-bs-slide="next">
                        <span class="carousel-control-next-icon" aria-hidden="true"></span>
                        <span class="visually-hidden">Successiva</span>
                    </button>
                </div>
            }
            else if (!string.IsNullOrWhiteSpace(Model.Coupon.ImagePath))
            {
                <img src="@Model.Coupon.ImagePath" class="coupon-detail-image" alt="Immagine coupon @Model.Coupon.Title" />
            }
            <div class="card-body p-4">
                <div class="d-flex flex-wrap gap-2 mb-2">
                    <span class="badge bg-primary">@Model.Coupon.CategoryName</span>
                    @if (Model.Coupon.IsBoostedInHome)
                    {
                        <span class="badge bg-warning text-dark">In evidenza</span>
                    }
                </div>

                <h1 class="h3 fw-bold mb-3">@Model.Coupon.Title</h1>
                <p class="text-secondary mb-3">Valido fino al <strong>@Model.Coupon.ValidTo.ToString("dd/MM/yyyy")</strong></p>

                <form asp-action="Download" method="post" class="d-inline-block">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="couponId" value="@Model.Coupon.Id" />
                    <button class="btn btn-success">Scarica coupon</button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-5">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-body p-4">
                <h2 class="h5 mb-3">Cliente</h2>
                <div class="d-flex align-items-center gap-3 mb-3">
                    @if (!string.IsNullOrWhiteSpace(Model.Coupon.BusinessLogoPath))
                    {
                        <img src="@Model.Coupon.BusinessLogoPath" class="business-logo" alt="Logo @Model.Coupon.BusinessName" />
                    }
                    else
                    {
                        <div class="business-logo d-flex align-items-center justify-content-center text-muted bg-light">Logo</div>
                    }
                    <div>
                        <div class="fw-semibold">@Model.Coupon.BusinessName</div>
                        @if (!string.IsNullOrWhiteSpace(Model.Coupon.BusinessCity))
                        {
                            <div class="small text-muted">@Model.Coupon.BusinessCity</div>
                        }
                    </div>
                </div>

                <div class="small text-muted">Download già effettuati: @Model.Coupon.DownloadsCount</div>
            </div>
        </div>
    </div>
</div>

<section class="mt-5">
    <h2 class="h4 mb-3">Altri coupon simili</h2>
    <div class="row g-3">
        @if (Model.SimilarCoupons.Any())
        {
            @foreach (var coupon in Model.SimilarCoupons)
            {
                <div class="col-md-6 col-xl-3">
                    <partial name="_CouponCard" model="coupon" />
                </div>
            }
        }
        else
        {
            <div class="col-12">
                <div class="alert alert-info rounded-4 mb-0">Nessun coupon simile disponibile al momento.</div>
            </div>
        }
    </div>
</section>
