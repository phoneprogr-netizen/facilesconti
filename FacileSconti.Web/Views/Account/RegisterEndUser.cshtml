@{
    ViewData["Title"] = "Registrazione Utente Finale";
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4 p-lg-5">
                <h1 class="h3 mb-2">Crea account utente finale</h1>
                <p class="text-secondary mb-4">Registrati per salvare e scaricare coupon.</p>

                <div asp-validation-summary="All" class="text-danger small mb-3"></div>

                <form method="post" asp-action="RegisterEndUser" class="row g-3">
                    @Html.AntiForgeryToken()

                    <div class="col-md-6">
                        <label class="form-label">Nome</label>
                        <input class="form-control" name="firstName" required />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Cognome</label>
                        <input class="form-control" name="lastName" required />
                    </div>

                    <div class="col-12">
                        <label class="form-label">Email</label>
                        <input type="email" class="form-control" name="email" required />
                    </div>

                    <div class="col-12">
                        <label class="form-label">Password</label>
                        <input type="password" class="form-control" name="password" minlength="8" required />
                    </div>

                    <div class="col-12 pt-2">
                        <button type="submit" class="btn btn-primary">Crea account</button>
                        <a asp-action="Login" class="btn btn-link">Hai già un account? Accedi</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
